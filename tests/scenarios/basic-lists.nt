md2html: true
html2md: true
markdown:
 > unordered lists
 >
 > - item 1
 > - item 2 **bold**
 > - item 3 `code`
 >
 > - item 1
 >
 > ordered list
 >
 > 1. item 1
 > 2. item 2 *italic*
 > 3. item 3 `code`
